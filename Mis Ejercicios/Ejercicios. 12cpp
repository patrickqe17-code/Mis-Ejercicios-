#include <iostream>
using namespace std;

int main() {

    int numero;

    cout << "Ingrese un numero de 4 digitos: ";
    cin >> numero;

    if(numero < 1000 || numero > 9999) {

        cout << "Numero invalido";
        return 0;
    }

    int d1 = numero / 1000;
    int d2 = (numero / 100) % 10;
    int d3 = (numero / 10) % 10;
    int d4 = numero % 10;

    d1 = (d1 + 7) % 10;
    d2 = (d2 + 7) % 10;
    d3 = (d3 + 7) % 10;
    d4 = (d4 + 7) % 10;

    int cifrado =
        d3 * 1000 +
        d4 * 100 +
        d1 * 10 +
        d2;

    cout << "Numero cifrado: "
         << cifrado;

    return 0;
}
